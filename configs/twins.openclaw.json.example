{
  "version": 1,
  "name": "{{DISPLAY_NAME_TWINS}}",
  "model": {
    "default": "{{AGENT_MODEL}}",
    "thinking": "adaptive"
  },
  "apiKeys": {
    "anthropic": "{{ANTHROPIC_API_KEY}}",
    "openai": "{{OPENAI_API_KEY}}",
    "deepseek": "{{DEEPSEEK_API_KEY}}"
  },
  "memory": {
    "enabled": true,
    "provider": "local",
    "embedding": {
      "provider": "{{EMBEDDING_PROVIDER}}",
      "model": "{{EMBEDDING_MODEL}}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {
          "botToken": "{{TELEGRAM_BOT_TOKEN_TWINS}}",
          "authorizedSenders": ["{{OWNER_TELEGRAM_ID}}"]
        }
      }
    }
  },
  "agents": {
    "remoteAgents": {
      "heisenberg": {
        "sessionKey": "agent:{{INTERNAL_NAME_HEISENBERG}}:main",
        "description": "Boss — main user-facing agent, escalations"
      },
      "saul": {
        "sessionKey": "agent:{{INTERNAL_NAME_SAUL}}:main",
        "description": "Producer — coordinates content pipeline, ОТК, delivery"
      },
      "walter": {
        "sessionKey": "agent:{{INTERNAL_NAME_WALTER}}:main",
        "description": "Tech lead — code, files, complex technical tasks"
      },
      "jesse": {
        "sessionKey": "agent:{{INTERNAL_NAME_JESSE}}:main",
        "description": "Marketing — funnels, CTR, analytics, copywriting"
      },
      "skyler": {
        "sessionKey": "agent:{{INTERNAL_NAME_SKYLER}}:main",
        "description": "Finance — budgets, expenses, financial reports"
      },
      "hank": {
        "sessionKey": "agent:{{INTERNAL_NAME_HANK}}:main",
        "description": "Security — audits, monitoring, QA"
      },
      "gus": {
        "sessionKey": "agent:{{INTERNAL_NAME_GUS}}:main",
        "description": "Kaizen — goals, habits, Obsidian, optimization"
      }
    }
  },
  "workspace": {
    "path": "~/openclaw-agents/twins"
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30
  },
  "exec": {
    "defaultTimeoutSeconds": 30
  }
}
