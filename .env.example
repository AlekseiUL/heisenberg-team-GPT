# ============================================
# Heisenberg Team - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Replace all {{PLACEHOLDER}} with actual data

# --- LLM Provider ---
# Uncomment YOUR provider:
ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key
# DEEPSEEK_API_KEY=your-deepseek-key

# --- Custom OpenAI-compatible / Anthropic-compatible endpoint (optional) ---
# Example: cliproxy, LiteLLM, vLLM, local gateway, self-hosted API
# CUSTOM_PROVIDER_ID=cliproxy
# CUSTOM_BASE_URL=http://127.0.0.1:4000/v1
# CUSTOM_MODEL_ID=gpt-4.1-mini
# CUSTOM_COMPATIBILITY=openai-completions
# CUSTOM_API_KEY=

# --- Embedding (for vector memory search) ---
# OpenAI recommended. Skip if you don't need semantic search.
# OPENAI_API_KEY=your-openai-key  # (same as above if using OpenAI as LLM)
# If you do not have a supported embedding key yet, choose "skip" in the wizard.
# The team will still start; memory search falls back to BM25/keyword mode.

# --- Models (set by setup wizard) ---
# MAIN_MODEL=anthropic/claude-opus-4-5       # For Heisenberg (boss)
# AGENT_MODEL=anthropic/claude-sonnet-4-5    # For other agents
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# --- Telegram (optional) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# OWNER_TELEGRAM_ID=your-telegram-id

# --- Personal Data ---
# Used in agent configs for personalization
OWNER_NAME=YourName
OWNER_SURNAME=YourSurname
OWNER_USERNAME=your-github-username

# --- Paths ---
# WORKSPACE_PATH=~/workspace/
# PROJECTS_PATH=~/projects/

# --- GitHub (optional) ---
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=your-github-token

# --- Webhooks (optional) ---
# WEBHOOK_TOKEN=your_webhook_token_here

# --- Notifications (optional) ---
# GROUP_CHAT_ID=your-group-chat-id
# NOTIFY_CHANNEL_ID=your-notify-channel-id
